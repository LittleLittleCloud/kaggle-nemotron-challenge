# Kaggle API credentials
# Get your key from https://www.kaggle.com/settings → "Create New Token"
KAGGLE_API_TOKEN=<your_kaggle_api_token_here>

KAGGLE_API_TOKEN_BACKUP=<your_kaggle_api_token_backup_here>

# HuggingFace token (for gated models like Nemotron)
# Get from https://huggingface.co/settings/tokens
HF_TOKEN=<your_huggingface_token_here>
